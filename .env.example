# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Application URL (for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail API Configuration (will be stored in database)
# Users configure their own credentials through the settings page

# ============================================================================
# Optional: Email Enrichment APIs (All Optional, System Works Without These)
# ============================================================================

# Google Custom Search API (Optional - Free 100 queries/day)
# Used as fallback for domain lookup when Clearbit/Brandfetch fail
# Sign up: https://developers.google.com/custom-search/v1/overview
# GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Abstract Email Validation API (Optional - $0.001 per verification)
# Disabled by default. Only enable if you want enhanced validation.
# System works perfectly fine with just MX verification (always free)
# Sign up: https://www.abstractapi.com/email-verification-validation-api
# ABSTRACT_EMAIL_VALIDATION_API_KEY=your-abstract-api-key
