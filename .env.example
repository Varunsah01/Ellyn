# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_CHROME_EXTENSION_ID=
SUPABASE_SERVICE_ROLE_KEY=

# ZeroBounce Email Validation API - https://www.zerobounce.net
ZEROBOUNCE_API_KEY=

# Email Verification Stack:
# - MX verification: DNS-based, built-in (no API key needed)
# - SMTP verification: ZeroBounce API (see ZEROBOUNCE_API_KEY above)

# Upstash Redis (for distributed rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis Cache (used by lib/cache/redis.ts)
# Prefer KV_* vars for @vercel/kv. UPSTASH_* vars are also supported as fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Performance monitoring thresholds
PERF_SLOW_OPERATION_MS=500
PERF_ALERT_API_RESPONSE_MS=1000
PERF_ALERT_ERROR_RATE_PERCENT=1
PERF_ALERT_DB_QUERY_MS=5000

# External API budget alerts (daily spend in USD; optional)
EXTERNAL_API_BUDGET_DAILY_USD=
EXTERNAL_API_BUDGET_ANTHROPIC_DAILY_USD=
EXTERNAL_API_BUDGET_ABSTRACT_DAILY_USD=
EXTERNAL_API_BUDGET_CLEARBIT_DAILY_USD=
EXTERNAL_API_BUDGET_BRANDFETCH_DAILY_USD=
EXTERNAL_API_BUDGET_GOOGLE_CUSTOM_SEARCH_DAILY_USD=
EXTERNAL_API_BUDGET_GOOGLE_DNS_DAILY_USD=
EXTERNAL_API_BUDGET_LINKEDIN_DAILY_USD=

# Admin / debug endpoint protection
ENABLE_DEBUG_ENDPOINTS=false
SECRET_ADMIN_TOKEN=
ADMIN_IP_WHITELIST=127.0.0.1

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
# "test_mode" or "live_mode"
DODO_PAYMENTS_ENVIRONMENT=test_mode
# Starter plan product IDs ($14.99/mo, $39.99/quarter — no yearly)
DODO_STARTER_PRODUCT_ID_GLOBAL_MONTHLY=
DODO_STARTER_PRODUCT_ID_GLOBAL_QUARTERLY=
# Pro plan product IDs ($34.99/mo, $89.99/quarter, $279/year)
DODO_PRO_PRODUCT_ID_GLOBAL_MONTHLY=
DODO_PRO_PRODUCT_ID_GLOBAL_QUARTERLY=
DODO_PRO_PRODUCT_ID_GLOBAL_YEARLY=
# Optional legacy fallback (used if cycle-specific IDs are not set)
DODO_PRO_PRODUCT_ID_GLOBAL=

# Sentry Error Monitoring
# Get these from https://sentry.io -> Settings -> Projects -> Your Project -> Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=ellyn
# Only needed for CI/CD source map uploads:
SENTRY_AUTH_TOKEN=sntrys_YOUR_AUTH_TOKEN
