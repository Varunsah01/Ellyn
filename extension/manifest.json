{
  "manifest_version": 3,
  "name": "Ellyn",
  "version": "1.0",
  "description": "Outreach Assistant",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel", "tabs", "storage"],
  "externally_connectable": {
    "matches": ["https://useellyn.com/*", "https://www.useellyn.com/*"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net;"
  },
  "action": {
    "default_title": "Open Side Panel"
  }
}
