{
  "manifest_version": 3,
  "name": "Ellyn - Email Discovery Workspace",
  "version": "2.0.0",
  "description": "Discover professional email addresses with manual input + API enrichment. NO LinkedIn scraping.",

  "permissions": [
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:3000/*"
  ],

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Open Ellyn Workspace",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
