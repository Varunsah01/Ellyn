{
  "manifest_version": 3,
  "name": "Ellyn",
  "version": "1.0",
  "description": "Ellyn - Outreach Assistant",
  "icons": {
    "16": "assets/icons/Ellynlogo.png",
    "48": "assets/icons/Ellynlogo.png",
    "128": "assets/icons/Ellynlogo.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["sidePanel", "tabs", "storage"],
  "externally_connectable": {
    "matches": [
      "https://useellyn.com/*",
      "https://www.useellyn.com/*",
      "https://ellyn.app/*",
      "https://www.ellyn.app/*",
      "https://app.ellyn.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline';"
  },
  "action": {
    "default_title": "Open Side Panel",
    "default_icon": {
      "16": "assets/icons/Ellynlogo.png",
      "48": "assets/icons/Ellynlogo.png",
      "128": "assets/icons/Ellynlogo.png"
    }
  }
}
