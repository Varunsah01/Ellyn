{
  "manifest_version": 3,
  "name": "Ellyn Email Finder",
  "version": "1.0.0",
  "description": "Find professional emails on LinkedIn with 95%+ accuracy",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "tabs", "sidePanel", "scripting", "alarms"],
  "host_permissions": [
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://*.ellyn.app/*",
    "https://ellyn.app/*",
    "https://www.ellyn.app/*",
    "https://app.ellyn.app/*",
    "https://useellyn.com/*",
    "https://www.useellyn.com/*",
    "https://dns.google/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://linkedin.com/*", "https://*.linkedin.com/*"],
      "js": ["content/linkedin-extractor.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Ellyn Email Finder",
    "default_icon": {
      "16": "assets/icons/Ellynlogo.png",
      "48": "assets/icons/Ellynlogo.png",
      "128": "assets/icons/Ellynlogo.png"
    }
  },
  "icons": {
    "16": "assets/icons/Ellynlogo.png",
    "48": "assets/icons/Ellynlogo.png",
    "128": "assets/icons/Ellynlogo.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://useellyn.com/*",
      "https://www.useellyn.com/*",
      "https://ellyn.app/*",
      "https://www.ellyn.app/*",
      "https://app.ellyn.app/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; style-src 'self' 'unsafe-inline';"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*", "icons/*"],
      "matches": ["https://linkedin.com/*", "https://*.linkedin.com/*"]
    }
  ]
}
