{
  "name": "ellyn",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "check:env-local": "node scripts/check-env-local-precedence.mjs",
    "security:scan": "bash scripts/security/scan-secrets.sh --strict",
    "security:scan:staged": "bash scripts/security/scan-secrets.sh --staged --strict",
    "security:install-hooks": "bash scripts/security/install-hooks.sh",
    "extension:public-config": "node scripts/security/generate-extension-public-config.mjs",
    "predev": "npm run check:env-local",
    "prebuild": "npm run check:env-local",
    "prestart": "npm run check:env-local",
    "dev": "next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('Cleaned .next cache');\"",
    "dev:clean": "npm run clean:next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:integration:coverage": "jest --config jest.integration.config.js --runInBand --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run lint && npm run test:coverage && npm run test:e2e",
    "seed:tracker": "node scripts/seed-tracker-test-data.mjs --mode=fixture --count=50",
    "seed:tracker:api": "node scripts/seed-tracker-test-data.mjs --mode=api --api=http://localhost:3000 --count=50 --clear-first",
    "seed:tracker:clear": "node scripts/seed-tracker-test-data.mjs --mode=api --api=http://localhost:3000 --clear-only",
    "seed:templates": "npx tsx scripts/seed-templates.ts",
    "seed:known-domains": "node scripts/seed-known-domains.mjs",
    "seed:known-domains:dry": "node scripts/seed-known-domains.mjs --dry-run",
    "seed:known-domains:csv": "node scripts/seed-known-domains.mjs --export-csv",
    "check:extension:globals": "node scripts/check-extension-global-collisions.js"
  },
  "dependencies": {
